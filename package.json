{
  "name": "hshub",
  "version": "6.0.0",
  "description": "HsHub — Moteur de recherche haute performance multi-bases",
  "main": "hshub-server.js",
  "scripts": {
    "start": "node --max-old-space-size=8192 hshub-server.js",
    "start:16g": "node --max-old-space-size=16384 hshub-server.js",
    "start:32g": "node --max-old-space-size=32768 hshub-server.js",
    "index": "node hshub-index.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
